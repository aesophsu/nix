#!/bin/sh
set -eu

usage() {
  echo "Usage: devshell-attach <base|python|node>" >&2
  exit 1
}

[ $# -eq 1 ] || usage

template="$1"
script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
templates_dir=$(CDPATH= cd -- "$script_dir/../share/devshell-templates" && pwd)
template_dir="$templates_dir/$template"

[ -d "$template_dir" ] || {
  echo "Unknown template: $template" >&2
  usage
}

if [ -e .envrc ]; then
  echo "Refusing to overwrite existing .envrc in $(pwd)" >&2
  exit 1
fi

if [ -e flake.nix ]; then
  cp "$template_dir/.envrc" ./.envrc
  echo "Added .envrc for existing flake.nix."
  echo "Next step: direnv allow"
  exit 0
fi

cp "$template_dir/flake.nix" ./flake.nix
cp "$template_dir/.envrc" ./.envrc

echo "Added flake.nix and .envrc from '$template'."
echo "Next step: direnv allow"
