(version 1)

; --------------------------------
; 默认全部拒绝
; --------------------------------
(deny default)

; 允许进程本身运行
(allow process*)
(allow sysctl-read)

; --------------------------------
; 文件读取：尽量宽松（否则 Nix 的可执行文件会被挡住）
; 允许读取所有路径
; --------------------------------
(allow file-read*)

; --------------------------------
; 文件写入：严格限制“OpenClaw 能改哪里”
; 只允许写入：
;   1) /Users/sue/openclaw_sandbox
;   2) /Users/sue/Documents/mimic/processed
;   3) /Users/sue/Documents/mimic/tables
;   4) /Users/sue/Documents/mimic/results
; --------------------------------
(allow file-write*
    (regex "^/Users/sue/openclaw_sandbox")
    (regex "^/Users/sue/Documents/mimic/results")
    (regex "^/Users/sue/Documents/mimic/docs")
    (regex "^/Users/sue/Documents/mimic/artifacts")
    (regex "^/Users/sue/Documents/mimic/validation") 
    (regex "^/Users/sue/Documents/mimic/scripts")
    (regex "^/Users/sue/Documents/mimic/data")
)

; 你如果之后要更细粒度控制，可以继续加 regex 白名单
; 例如：
; (regex "^/Users/sue/Documents/mimic/results/table[0-9]+\\.csv$")
