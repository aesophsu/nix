# Copy to scripts/build-nixos-iso-remote.env.local and fill in your remote builder info.
# This file is intentionally safe to commit; .env.local is gitignored.

# Required (unless passed via CLI)
NIX_ISO_REMOTE_HOST="your-linux-builder"
NIX_ISO_REMOTE_DIR="/srv/nix-iso-build"

# Optional defaults
# NIX_ISO_ALIAS="shaka-installer-iso"
# NIX_ISO_LOCAL_OUT_DIR="/Users/sue/Code/nix/archive/iso-out"
# NIX_ISO_FLAKE_SUBPATH="."

# Optional extra SSH options (prefer SSH config alias when possible)
# NIX_ISO_SSH_OPTS="-o BatchMode=yes"

# Keep remote uploaded workspace after success (1 = keep, 0 = cleanup)
# NIX_ISO_KEEP_REMOTE=0
